// TCG Analytics — Prisma schema
// Models the JustTCG data hierarchy (Game → Set → Card → Variant → PriceSnapshot)
// in a TCG-agnostic way so Pokémon, Riftbound, and others share one shape.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

/// A trading card game (e.g. "pokemon", "riftbound"). Top of the hierarchy.
model Game {
  id        Int      @id @default(autoincrement())
  /// Stable slug used by JustTCG, e.g. "pokemon". Unique across the platform.
  key       String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sets  Set[]
  cards Card[]

  @@map("games")
}

/// A card set / expansion within a game.
model Set {
  id          Int       @id @default(autoincrement())
  /// JustTCG set identifier, if provided by the API.
  justTcgId   String?   @unique
  gameId      Int
  name        String
  /// Short set code, e.g. "sv1". Unique within a game.
  code        String?
  releaseDate DateTime?
  cardCount   Int?
  /// Era/series this set rolls up into, e.g. "Scarlet & Violet". Assigned during
  /// ingestion by lib/justtcg/series.ts (curated map + release-date fallback);
  /// JustTCG has no series field of its own.
  series      String?
  /// When this set's cards were last synced from JustTCG (drives resumable
  /// ingestion order and the UI freshness badge).
  lastSyncedAt DateTime?
  /// Optional aggregate analytics JustTCG exposes on the set object.
  setValueUsd         Float?
  setValueChange7dPct Float?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  game  Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  cards Card[]

  @@unique([gameId, code])
  @@index([gameId])
  @@index([series])
  @@map("sets")
}

/// A single card. Printings/conditions that carry prices live in CardVariant.
model Card {
  id          Int      @id @default(autoincrement())
  /// JustTCG card id — the canonical external identifier.
  justTcgId   String   @unique
  gameId      Int
  setId       Int?
  name        String
  /// Collector number within the set, e.g. "25" or "TG05".
  number      String?
  rarity      String?
  /// TCGplayer product id, handy for cross-referencing.
  tcgplayerId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  game     Game          @relation(fields: [gameId], references: [id], onDelete: Cascade)
  set      Set?          @relation(fields: [setId], references: [id], onDelete: SetNull)
  variants CardVariant[]

  @@index([gameId])
  @@index([setId])
  @@index([name])
  @@map("cards")
}

/// A priceable printing+condition of a card (e.g. Holofoil / Near Mint).
/// Holds the latest snapshot values; historical points live in PriceSnapshot.
model CardVariant {
  id        Int      @id @default(autoincrement())
  /// JustTCG variant id, if provided.
  justTcgId String?  @unique
  cardId    Int
  /// e.g. "Near Mint", "Lightly Played".
  condition String?
  /// e.g. "Normal", "Holofoil", "Reverse Holofoil".
  printing  String?
  language  String?  @default("EN")

  /// Latest known market price, denormalized for quick reads.
  latestPrice Float?
  currency    String  @default("USD")
  lastSeenAt  DateTime?

  /// JustTCG price-analytics fields (percentages are % values, e.g. -2.1 = -2.1%).
  priceChange7d   Float?
  priceChange24hr Float?
  avgPrice        Float?
  minPrice7d      Float?
  maxPrice7d      Float?
  /// 7-day volatility signals (used to filter out thin/churny "movers").
  /// priceChangesCount7d = # of discrete price changes in the window (0 = flat,
  /// 1 = one clean step, high = churning). covPrice7d = coefficient of variation
  /// (stddev/mean); interpret relative to the move size, not as an absolute cap.
  priceChangesCount7d Int?
  covPrice7d          Float?
  /// Derived "7 days ago" entry price = latestPrice / (1 + priceChange7d/100).
  /// Enables the either-end-in-band price filter; null when priceChange7d is null.
  startPrice7d    Float?
  /// JustTCG variant `lastUpdated` (epoch seconds) as a timestamp.
  apiLastUpdated  DateTime?

  /// --- Extended multi-horizon analytics (JustTCG) -------------------------
  /// Raw stat fields for predictive/technical screening. All nullable (sparse
  /// API data). Composite signals (MA-cross, %B, distance-to-ATH, health score)
  /// are derived from these in the query layer, not stored. NOTE: JustTCG has
  /// no volume/quantity-sold field — the *Count fields are a repricing-frequency
  /// (attention/liquidity) proxy, not true demand.
  /// Momentum: % change over each window (7d above; 30d/90d here).
  priceChange30d  Float?
  priceChange90d  Float?
  /// Linear-regression slope of price over each window (trend robustness).
  trendSlope7d    Float?
  trendSlope30d   Float?
  trendSlope90d   Float?
  /// Position within the window's [min,max] range, 0..1 (stochastic-style
  /// overbought/oversold). ~0 = oversold, ~1 = extended/near-high.
  priceRelativeTo30dRange Float?
  priceRelativeTo90dRange Float?
  /// Window averages (moving-average-cross signals vs latestPrice).
  avgPrice30d     Float?
  avgPrice90d     Float?
  /// Support/resistance anchors per window + 1y + all-time (with dates).
  minPrice30d         Float?
  maxPrice30d         Float?
  minPrice90d         Float?
  maxPrice90d         Float?
  minPrice1y          Float?
  maxPrice1y          Float?
  minPriceAllTime     Float?
  minPriceAllTimeDate DateTime?
  maxPriceAllTime     Float?
  maxPriceAllTimeDate DateTime?
  /// Dispersion: population stddev (band width), coefficient of variation
  /// (unit-free screening), and IQR (outlier-resistant) per window.
  stddevPopPrice7d  Float?
  stddevPopPrice30d Float?
  stddevPopPrice90d Float?
  covPrice30d       Float?
  covPrice90d       Float?
  iqrPrice7d        Float?
  iqrPrice30d       Float?
  iqrPrice90d       Float?
  /// Repricing frequency per window (liquidity/attention proxy, NOT volume).
  priceChangesCount30d Int?
  priceChangesCount90d Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  card      Card           @relation(fields: [cardId], references: [id], onDelete: Cascade)
  snapshots PriceSnapshot[]

  @@unique([cardId, printing, condition, language])
  @@index([cardId])
  @@index([priceChange7d])
  @@index([priceChange30d])
  @@index([latestPrice])
  @@index([startPrice7d])
  @@index([priceChangesCount7d])
  @@map("card_variants")
}

/// A point-in-time price observation for a variant — the core time series
/// that analytics queries aggregate over.
model PriceSnapshot {
  id        Int      @id @default(autoincrement())
  variantId Int
  price     Float
  currency  String   @default("USD")
  /// Optional richer fields JustTCG exposes for trend analysis.
  marketPrice Float?
  lowPrice    Float?
  highPrice   Float?
  recordedAt DateTime @default(now())

  variant CardVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([variantId, recordedAt])
  @@index([variantId, recordedAt])
  @@map("price_snapshots")
}
